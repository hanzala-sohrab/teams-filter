{
  "manifest_version": 3,
  "name": "Teams Message Filter",
  "version": "1.0.0",
  "description": "Auto-hide or delete messages from specified people on Microsoft Teams",
  "browser_specific_settings": {
    "gecko": {
      "id": "teams-filter@local",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://teams.microsoft.us/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams Message Filter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
